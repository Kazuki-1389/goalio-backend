# Render production environment variables.
APP_ENV=production
FIREBASE_PROJECT_ID=goalio-c42bc
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/firebase-service-account.json
ALLOWED_ORIGINS=
ALLOW_DEV_AUTH=false
API_FOOTBALL_KEY=add-as-a-render-secret-environment-variable
FOOTBALL_DATA_API_KEY=add-as-a-render-secret-environment-variable
FOOTBALL_SEASON=2026
FOOTBALL_SYNC_MAX_REQUESTS=250
FOOTBALL_REQUEST_INTERVAL_SECONDS=6.2
ESPN_REQUEST_INTERVAL_SECONDS=0.5
API_FOOTBALL_MAX_REQUESTS=95

# Render supplies PORT automatically. Do not add FIREBASE_SERVICE_ACCOUNT_JSON
# when GOOGLE_APPLICATION_CREDENTIALS points to the Render Secret File.
