APP_ENV=development
FIREBASE_PROJECT_ID=goalio-c42bc
# Render Secret File (recommended for Render deployments):
# GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/firebase-service-account.json
# Local secret file:
# GOOGLE_APPLICATION_CREDENTIALS=C:/secure/path/firebase-service-account.json
# Alternative when secret files are unavailable:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
ALLOWED_ORIGINS=http://localhost:3000
ALLOW_DEV_AUTH=false

# When true together with APP_ENV=development, unauthenticated local Swagger
# requests use the isolated uid "swagger-user". Never enable in production.
