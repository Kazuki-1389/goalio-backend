# Copy this file to .env for local development.
APP_ENV=development
FIREBASE_PROJECT_ID=goalio-c42bc
GOOGLE_APPLICATION_CREDENTIALS=C:/absolute/path/to/firebase-service-account.json
ALLOWED_ORIGINS=http://localhost:3000
ALLOW_DEV_AUTH=true
API_FOOTBALL_KEY=replace-with-your-api-football-key
FOOTBALL_DATA_API_KEY=replace-with-your-football-data-org-token
FOOTBALL_SEASON=2026
FOOTBALL_SYNC_MAX_REQUESTS=250
FOOTBALL_REQUEST_INTERVAL_SECONDS=6.2
ESPN_REQUEST_INTERVAL_SECONDS=0.5
